<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Calcar — Traza tu dibujo</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');

  :root {
    --bg: #0d0d0d;
    --surface: #1a1a1a;
    --border: #2e2e2e;
    --accent: #e8ff47;
    --accent-dim: #c8df30;
    --text: #f0f0f0;
    --text-muted: #666;
    --radius: 14px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  html, body {
    width: 100%; height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    overflow: hidden;
  }

  /* ── PANTALLA DE BIENVENIDA ── */
  #welcome {
    position: fixed; inset: 0; z-index: 100;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: var(--bg);
    padding: 32px 24px;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  #welcome.hidden {
    opacity: 0; transform: translateY(-30px); pointer-events: none;
  }

  .logo-mark {
    width: 72px; height: 72px;
    background: var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
    animation: pulse 2.5s ease-in-out infinite;
  }

  .logo-mark svg { width: 36px; height: 36px; }

  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(232,255,71,0.4); }
    50% { transform: scale(1.05); box-shadow: 0 0 0 16px rgba(232,255,71,0); }
  }

  #welcome h1 {
    font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em;
    line-height: 1; text-align: center; margin-bottom: 10px;
  }

  #welcome h1 span { color: var(--accent); }

  #welcome p {
    font-size: 0.95rem; color: var(--text-muted); text-align: center;
    line-height: 1.6; max-width: 280px; margin-bottom: 40px;
  }

  .btn-upload {
    width: 100%; max-width: 300px;
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: var(--radius);
    padding: 18px 0;
    font-family: 'Syne', sans-serif;
    font-size: 1rem; font-weight: 800;
    letter-spacing: 0.04em;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .btn-upload:active { transform: scale(0.97); }

  .btn-upload::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.08);
    opacity: 0; transition: opacity 0.15s;
  }

  .btn-upload:active::after { opacity: 1; }

  #fileInput { display: none; }

  .hint {
    margin-top: 20px;
    font-size: 0.75rem; color: var(--text-muted);
    font-family: 'Space Mono', monospace;
    display: flex; align-items: center; gap: 6px;
  }

  .hint::before, .hint::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  /* ── ÁREA DE CALCO ── */
  #app {
    position: fixed; inset: 0; z-index: 10;
    display: flex; flex-direction: column;
    opacity: 0; pointer-events: none;
    transition: opacity 0.5s ease;
  }

  #app.visible { opacity: 1; pointer-events: all; }

  /* Visor de cámara / lienzo */
  #viewer {
    position: relative;
    flex: 1;
    overflow: hidden;
    background: #000;
    display: flex; align-items: center; justify-content: center;
  }

  /* Vídeo de la cámara */
  #camera {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  /* Imagen de referencia encima */
  #refImage {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    transition: opacity 0.05s;
    pointer-events: none;
  }

  /* Overlay decorativo */
  .grid-overlay {
    position: absolute; inset: 0; pointer-events: none; z-index: 5;
    background-image:
      linear-gradient(rgba(232,255,71,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,255,71,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Esquinas decorativas */
  .corner {
    position: absolute; width: 24px; height: 24px; z-index: 6;
    pointer-events: none;
  }
  .corner-tl { top: 12px; left: 12px; border-top: 2px solid var(--accent); border-left: 2px solid var(--accent); }
  .corner-tr { top: 12px; right: 12px; border-top: 2px solid var(--accent); border-right: 2px solid var(--accent); }
  .corner-bl { bottom: 12px; left: 12px; border-bottom: 2px solid var(--accent); border-left: 2px solid var(--accent); }
  .corner-br { bottom: 12px; right: 12px; border-bottom: 2px solid var(--accent); border-right: 2px solid var(--accent); }

  /* Etiqueta opacidad en vivo */
  #opacityLabel {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    z-index: 7;
    background: rgba(0,0,0,0.6);
    border: 1px solid var(--border);
    border-radius: 30px;
    padding: 4px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem; color: var(--accent);
    backdrop-filter: blur(8px);
    transition: opacity 0.3s;
  }

  /* ── PANEL INFERIOR ── */
  #panel {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 20px 24px 32px;
    display: flex; flex-direction: column; gap: 18px;
  }

  .panel-header {
    display: flex; align-items: center; justify-content: space-between;
  }

  .panel-title {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-muted);
    font-family: 'Space Mono', monospace;
  }

  .btn-change {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem; color: var(--text-muted);
    cursor: pointer; transition: all 0.15s;
  }

  .btn-change:active { background: var(--border); color: var(--text); }

  /* Slider de opacidad */
  .slider-wrap {
    display: flex; align-items: center; gap: 14px;
  }

  .slider-icon { font-size: 1.1rem; line-height: 1; flex-shrink: 0; }

  input[type=range] {
    -webkit-appearance: none;
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--accent) var(--pct, 80%), var(--border) var(--pct, 80%));
    outline: none;
    cursor: pointer;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 2px 8px rgba(232,255,71,0.5);
    cursor: grab;
    transition: transform 0.1s;
  }

  input[type=range]:active::-webkit-slider-thumb {
    transform: scale(1.2); cursor: grabbing;
  }

  /* Botones de preset */
  .presets {
    display: flex; gap: 8px;
  }

  .preset-btn {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 0;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem; color: var(--text-muted);
    cursor: pointer; transition: all 0.15s;
  }

  .preset-btn:active, .preset-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #000; font-weight: 700;
  }

  /* Estado: sin imagen */
  #placeholder {
    position: absolute; inset: 0; z-index: 8;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 12px;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    pointer-events: none;
  }

  #placeholder p {
    font-size: 0.85rem; color: var(--text-muted); text-align: center;
    max-width: 200px; line-height: 1.5;
  }

  #placeholder svg { opacity: 0.3; }

  /* ── ANIMACIÓN ENTRADA ── */
  @keyframes slideUp {
    from { transform: translateY(40px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  #panel { animation: slideUp 0.4s 0.1s both; }
</style>
</head>
<body>

<!-- ══════════ PANTALLA DE BIENVENIDA ══════════ -->
<div id="welcome">
  <div class="logo-mark">
    <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M6 30L18 6L30 30" stroke="#000" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 22H26" stroke="#000" stroke-width="3" stroke-linecap="round"/>
      <circle cx="18" cy="16" r="2" fill="#000"/>
    </svg>
  </div>
  <h1>CALCAR<br/><span>DIBUJO</span></h1>
  <p>Sube una imagen de referencia y trázala sobre papel con la ayuda de la cámara.</p>
  <button class="btn-upload" onclick="document.getElementById('fileInput').click()">
    📁 &nbsp; SUBIR IMAGEN
  </button>
  <input type="file" id="fileInput" accept="image/*" onchange="loadImage(event)">
  <span class="hint">o usa la cámara trasera</span>
</div>

<!-- ══════════ ÁREA DE CALCO ══════════ -->
<div id="app">
  <div id="viewer">
    <video id="camera" autoplay playsinline muted></video>
    <img id="refImage" src="" alt="referencia" style="opacity:0.8">
    <div class="grid-overlay"></div>
    <div class="corner corner-tl"></div>
    <div class="corner corner-tr"></div>
    <div class="corner corner-bl"></div>
    <div class="corner corner-br"></div>
    <div id="opacityLabel">80%</div>

    <!-- Placeholder cuando no hay imagen -->
    <div id="placeholder">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <rect x="6" y="10" width="36" height="28" rx="4" stroke="#fff" stroke-width="2"/>
        <circle cx="18" cy="20" r="4" stroke="#fff" stroke-width="2"/>
        <path d="M6 34L16 24L22 30L30 22L42 34" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <p>Sube una imagen para empezar a calcar</p>
    </div>
  </div>

  <div id="panel">
    <div class="panel-header">
      <span class="panel-title">Opacidad de referencia</span>
      <button class="btn-change" onclick="document.getElementById('fileInput2').click()">
        Cambiar imagen
      </button>
      <input type="file" id="fileInput2" accept="image/*" onchange="loadImage(event)" style="display:none">
    </div>

    <div class="slider-wrap">
      <span class="slider-icon">🌑</span>
      <input type="range" id="opacitySlider" min="0" max="100" value="80"
             oninput="setOpacity(this.value)">
      <span class="slider-icon">☀️</span>
    </div>

    <div class="presets">
      <button class="preset-btn" onclick="setPreset(25)">25%</button>
      <button class="preset-btn" onclick="setPreset(50)">50%</button>
      <button class="preset-btn active" onclick="setPreset(80)">80%</button>
      <button class="preset-btn" onclick="setPreset(100)">100%</button>
    </div>
  </div>
</div>

<script>
  const welcome     = document.getElementById('welcome');
  const app         = document.getElementById('app');
  const camera      = document.getElementById('camera');
  const refImage    = document.getElementById('refImage');
  const slider      = document.getElementById('opacitySlider');
  const label       = document.getElementById('opacityLabel');
  const placeholder = document.getElementById('placeholder');

  // ── Iniciar cámara ──
  async function startCamera() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: 'environment' }, width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false
      });
      camera.srcObject = stream;
    } catch (err) {
      console.warn('Cámara no disponible:', err);
      camera.style.background = '#111';
    }
  }

  // ── Cargar imagen ──
  function loadImage(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      refImage.src = e.target.result;
      placeholder.style.display = 'none';

      // Mostrar app
      welcome.classList.add('hidden');
      app.classList.add('visible');
      startCamera();
      updateSlider(80);
    };
    reader.readAsDataURL(file);
    event.target.value = '';
  }

  // ── Opacidad ──
  function setOpacity(val) {
    const v = parseInt(val);
    refImage.style.opacity = v / 100;
    label.textContent = v + '%';
    updateSlider(v);
    updatePresetHighlight(v);
  }

  function updateSlider(val) {
    slider.value = val;
    slider.style.setProperty('--pct', val + '%');
  }

  function setPreset(val) {
    setOpacity(val);
    label.style.opacity = '1';
  }

  function updatePresetHighlight(val) {
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.textContent) === val);
    });
  }

  // Ocultar label de opacidad después de un momento
  let hideTimer;
  slider.addEventListener('input', () => {
    label.style.opacity = '1';
    clearTimeout(hideTimer);
    hideTimer = setTimeout(() => { label.style.opacity = '0.4'; }, 1500);
  });

  // Init
  updateSlider(80);
</script>
</body>
</html>
